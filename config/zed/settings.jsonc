// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "right",
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "file_scan_exclusions": ["**/vendor"],
  "diff_view_style": "unified",
  "auto_signature_help": true,
  "show_signature_help_after_edits": true,
  "agent": {
    "message_editor_min_lines": 5,
    "single_file_review": true,
    "dock": "left",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5.3-codex",
    },
    "favorite_models": [],
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-5.3-codex",
    },
    "model_parameters": [],
  },
  "edit_predictions": {
    "provider": "copilot",
    "mode": "subtle",
  },
  "show_edit_predictions": true,
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "inlay_hints": {
    "show_background": false,
    "edit_debounce_ms": 250,
  },
  "git_panel": {
    "dock": "right",
    "tree_view": true,
  },
  "tab_bar": {
    "show": true,
  },
  "which_key": { "enabled": true, "delay_ms": 0 },
  "helix_mode": true,
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Catppuccin Frappé",
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": true,
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "Catppuccin Frappé",
    "dark": "Catppuccin Frappé"
  },
  "lsp": {
    "golangci-lint": {
      "initialization_options": {
        "command": [
          "golangci-lint",
          "run",
          "--output.json.path=stdout",
          "--show-stats=false",
          "--issues-exit-code=1",
        ],
      },
    },
  },
  "languages": {
    "Just": {
      "format_on_save": "off",
    },
    "Go": {
      "language_servers": ["gopls", "golangci-lint"],
    },
    "Python": {
      "language_servers": [
        "ty",
        "ruff",
        "!basedpyright",
        "!pyrefly",
        "!pyright",
        "!pylsp",
      ],
      "Nix": {
        "formatter": {
          "external": {
            "command": "nixfmt",
            "arguments": ["--quiet", "--"],
          },
        },
      },
    },
  },
}
